{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "restore",
      "type": "process",
      "command": "dotnet",
      "args": [
        "restore",
        "${workspaceFolder}/TreeSync.sln"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: solution",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/TreeSync.sln"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: cli",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/TreeSync.Cli/TreeSync.Cli.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/TreeSync.Tests/TreeSync.Tests.csproj"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish: win-x64 folder",
      "type": "process",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/src/TreeSync.Cli/TreeSync.Cli.csproj",
        "-c",
        "Release",
        "-p:PublishProfile=win-x64-folder"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
